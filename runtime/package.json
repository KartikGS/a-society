{
  "name": "a-society-runtime",
  "version": "0.1.0",
  "description": "Unified executable layer for the A-Society framework",
  "type": "module",
  "bin": {
    "a-society": "./bin/a-society"
  },
  "scripts": {
    "start": "tsx src/server/server.ts",
    "build:ui": "vite build",
    "build": "tsc && npm run build:ui",
    "lint": "eslint .",
    "check": "npm run lint && npm run build && npm test",
    "test": "tsx test/run-tests.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.0",
    "@dagrejs/dagre": "^3.0.0",
    "@opentelemetry/api": "1.7.0",
    "@opentelemetry/context-async-hooks": "^1.30.1",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.47.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.47.0",
    "@opentelemetry/resources": "^1.30.1",
    "@opentelemetry/sdk-node": "^0.47.0",
    "@opentelemetry/sdk-trace-base": "^1.30.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "dotenv": "^16.0.0",
    "express": "^4.21.2",
    "js-yaml": "^4.1.0",
    "openai": "^4.0.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.10.0",
