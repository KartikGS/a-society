    "@types/express": "^5.0.1",
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/ws": "^8.5.14",
    "@vitejs/plugin-react": "^4.4.1",
    "@xyflow/react": "^12.6.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.5.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.59.0",
    "vite": "^6.3.5"
