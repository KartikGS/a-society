{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "composite": true,
    "declaration": true,
    "rootDir": "shared",
    "outDir": "dist/shared",
    "tsBuildInfoFile": "dist/tsconfig.shared.tsbuildinfo",
    "types": []
  },
  "include": ["shared/**/*"]
}
