# A-Society Runtime Configuration Template
# Copy this file to .env and populate with your keys and settings

# --- PROVIDER CONFIGURATION ---

# Provider selector (anthropic | openai-compatible)
# Default: anthropic
LLM_PROVIDER=anthropic

# ANTHROPIC: required if LLM_PROVIDER is anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Anthropic model override
# Default: claude-3-5-sonnet-20241022
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# OPENAI-COMPATIBLE: required if LLM_PROVIDER is openai-compatible
# OPENAI_COMPAT_BASE_URL=https://api.example.com/v1
# OPENAI_COMPAT_API_KEY=your_provider_api_key_here
# OPENAI_COMPAT_MODEL=mistralai/Mistral-7B-Instruct-v0.3
