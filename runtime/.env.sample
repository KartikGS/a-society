# A-Society Runtime Configuration Template
# Copy this file to .env and populate with your keys and settings

# --- MODEL CONFIGURATION ---

# Configure provider, model, base URL, and API key from the runtime Settings UI.
# The runtime no longer reads model/provider credentials from .env.

# --- TOOL CONFIGURATION ---

# Tavily API key — required to enable the web_search tool.
# Get one at https://app.tavily.com
# If unset, web_search will not be registered as a tool.
# TAVILY_API_KEY=your_tavily_api_key_here

# --- OBSERVABILITY CONFIGURATION ---

# Set to false to disable runtime telemetry bootstrapping entirely.
# A_SOCIETY_TELEMETRY_ENABLED=true

# OTLP/HTTP collector endpoint.
# Dedicated A-Society local stack: http://localhost:14318
# If you already run another local collector (for example llm-journey), point this to that endpoint instead.
# A_SOCIETY_OTLP_ENDPOINT=http://localhost:14318

# Optional OTLP headers, comma-separated key=value pairs.
# A_SOCIETY_OTLP_HEADERS=x-otlp-key=example

# Metrics export interval in milliseconds. Default: 60000
# A_SOCIETY_OTLP_METRICS_INTERVAL=10000

# Set to true to capture prompt/turn payload snippets in span events.
# Warning: captured payloads may contain sensitive data.
# A_SOCIETY_TELEMETRY_PAYLOAD_CAPTURE=false

# Resource attribute for deployment.environment.
# A_SOCIETY_ENVIRONMENT=development
