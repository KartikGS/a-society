{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "composite": true,
    "rootDir": ".",
    "outDir": "./dist",
    "tsBuildInfoFile": "./dist/tsconfig.node.tsbuildinfo",
    "types": ["node"]
  },
  "include": ["src/**/*", "test/**/*"],
  "references": [
    { "path": "./tsconfig.shared.json" },
    { "path": "./tsconfig.app.json" }
  ]
}
